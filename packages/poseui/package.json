{
  "name": "poseui",
  "version": "0.0.6",
  "description": "Type-safe HTML templating engine on steroids",
  "license": "MIT",
  "author": "Ryuz <ryuzer@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guarana-studio/poseui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./presets/tailwind4": {
      "types": "./dist/presets/tailwind4/index.d.ts",
      "import": "./dist/presets/tailwind4/index.js"
    },
    "./presets/basecoat": {
      "types": "./dist/presets/basecoat/index.d.ts",
      "import": "./dist/presets/basecoat/index.js"
    },
    "./presets/reactive": {
      "types": "./dist/presets/reactive/index.d.ts",
      "import": "./dist/presets/reactive/index.js"
    },
    "./unocss": {
      "types": "./dist/unocss/index.d.ts",
      "import": "./dist/unocss/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsdown",
    "fmt": "oxfmt",
    "test": "bun test",
    "docs:build": "docsome build DOCS.md --outDir docs_dist",
    "docs:dev": "docsome dev DOCS.md",
    "cleanup": "rimraf dist node_modules"
  },
  "dependencies": {
    "@poseui/match": "workspace:*"
  },
  "devDependencies": {
    "@poseui/store": "workspace:*",
    "@unocss/core": "^66.6.7",
    "docsome": "^0.0.1",
    "oxfmt": "^0.41.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
